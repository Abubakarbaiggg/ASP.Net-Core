@model ASP.Net_Core.ViewModels.CreateStudentViewModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Student</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                @if (Model.Courses != null && Model.Courses.Count > 0)
                {
                    for (int i = 0; i < Model.Courses.Count; i++)
                    {
                        <div class="form-check">
                            <input asp-for="Courses[i].Selected" class="form-check-input" />
                            <input asp-for="Courses[i].Value" type="hidden" />
                            <label class="form-check-label">@Model.Courses[i].Text</label>
                        </div>
                    }
                }
                else
                {
                    <p>No courses available.</p>
                }
            </div>
            <div class="form-group">
                <label asp-for="Enrolled" class="control-label"></label>
                <input asp-for="Enrolled" class="form-control" />
                <span asp-validation-for="Enrolled" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
